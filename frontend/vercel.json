{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/config",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/app-entrypoint/manifest",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/mobile-shell/app.js",
      "dest": "/mobile-shell/app.js"
    },
    {
      "src": "/mobile-shell/styles.css",
      "dest": "/mobile-shell/styles.css"
    },
    {
      "src": "/mobile-shell/manifest.json",
      "dest": "/mobile-shell/manifest.json"
    },
    {
      "src": "/mobile-shell",
      "dest": "/mobile-shell/index.html"
    },
    {
      "src": "/app/mobile",
      "dest": "/mobile-shell/index.html"
    },
    {
      "src": "/app/apk-start",
      "dest": "/mobile-shell/index.html"
    },
    {
      "src": "/mobile",
      "dest": "/mobile-shell/index.html"
    },
    {
      "src": "/app/home",
      "dest": "/index.html"
    },
    {
      "src": "/app",
      "dest": "/index.html"
    },
    {
      "src": "/desktop",
      "dest": "/index.html"
    },
    {
      "src": "/home",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
